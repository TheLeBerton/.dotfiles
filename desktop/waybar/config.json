{
	"layer": "top",
	"spacing": 4,
	"margin": "8 14 0 14",
	"modules-left": ["custom/logo"],
	"modules-center": ["clock", "hyprland/workspaces"],
	"modules-right": ["pulseaudio", "network", "battery", "tray"],

	"custom/logo": {
