{
	"layer": "top",
	"spacing": 8,
	"modules-left": ["custom/logo"],
	"modules-center": ["clock", "hyprland/workspaces"],
	"modules-right": ["pulseaudio", "network", "battery"],

	"custom/logo": {
		"format": "â—†",
