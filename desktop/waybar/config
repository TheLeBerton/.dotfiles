{
		"layer": "top",
		"position": "top",
		"spacing": 0,
		"height": 28,
		"modules-left": [
				"hyprland/workspaces"
		],
		"modules-center": [
				"clock"
		],
		"modules-right": [
				"custom/pomodoro",
				"wireplumber",
				"network",
				"battery",
				"custom/nordvpn",
				"custom/brightness"
		],
		"hyprland/workspaces": {
				"on-click": "activate",
				"format": "{icon}",
				"format-icons": {
						"default": "○",
						"active": "●",
						"urgent": "!"
				},
				"persistent_workspaces": {
						"1": [],
						"2": [],
						"3": [],
						"4": [],
						"5": []
				}
		},
		"clock": {
				"tooltip-format": "{calendar}",
				"format": "{:%H:%M}"
		},
		"network": {
				"format-wifi" : "{icon}",
				"format-icons": ["󰤯","󰤟","󰤢","󰤥","󰤨"],
				"format-ethernet": "󰀂",
				"format-alt" : "󱛇",
				"format-disconnected" : "󰖪",
				"tooltip-format-wifi": "{essid}  {signalStrength}%",
				"tooltip-format-ethernet": "{ifname}",
				"tooltip-format-disconnected": "Disconnected",
				"on-click": "~/.config/rofi/wifi/wifi.sh &",
				"interval": 5
		},
		"custom/pomodoro": {
			"exec": "$HOME/.local/scripts/pomodoro.sh status",
			"return-type": "json",
			"interval": 1,
			"on-click": "$HOME/.local/scripts/pomodoro.sh toggle",
			"on-click-right": "$HOME/.local/scripts/pomodoro.sh skip"
	},
	"custom/nordvpn": {
				"interval": 3,
				"exec": "nordvpn status | grep -q Disconnected && echo '{\"text\":\"\uf127\", \"class\":\"disconnected\"}' || echo '{\"text\":\"\uf0c1\", \"class\":\"connected\"}'",
				"return-type": "json",
				"format": "{}"
		},
		"custom/brightness": {
				"exec": "$HOME/.local/scripts/brightness.sh",
				"interval": 3
		},
		"wireplumber": {
				"format": "{icon}",
				"format-bluetooth": "󰂰",
				"tooltip-format": "{volume}%",
				"format-muted": "󰝟",
				"format-icons": {
						"headphone": "",
						"default": ["󰖀","󰕾",""]
				},
				"on-click": "pamixer -t",
				"scroll-step": 1
		},
		"battery": {
				"bat": "macsmc-battery",
				"format": "{icon} {capacity}%",
				"format-charging": "󰂄 {capacity}%",
				"format-plugged": " {capacity}%",
				"format-icons": {
						"default": ["󰁺","󰁻","󰁼","󰁽","󰁾","󰁿","󰂀","󰂁","󰂂","󰁹"]
				},
				"format-full": "",
				"interval": 5,
				"states": {
						"warning": 20,
						"critical": 10
				},
				"tooltip": false
		}
}
